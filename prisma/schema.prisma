generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id         String    @id @default(cuid())
  userId     String
  name       String
  sku        String?   @unique
  price      Decimal   @db.Decimal(12, 2)
  quantity   Int       @default(0)
  lowStock   Int?
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expiryDate DateTime?
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([createdBy])
  @@index([userId])
  @@index([userId, name])
}

model User {
  id         String    @id @default(cuid())
  email         String    @unique
  name          String?
  hexclaveId    String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)
  Product       Product[]

  @@index([email])
  @@index([role])
}

enum Role {
  MANAGER
  STAFF
}
